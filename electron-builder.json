{
  "appId": "com.todofocus.app",
  "productName": "TodoFocus",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "electron/**/*",
    ".next/standalone/**/*",
    "prisma/**/*",
    "package.json"
  ],
  "extraResources": [],
  "mac": {
    "target": ["dmg", "zip"],
    "icon": "public/icon.icns",
    "category": "public.app-category.productivity",
    "darkModeSupport": true
  },
  "win": {
    "target": ["nsis", "zip"],
    "icon": "public/icon.ico"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "icon": "public/icon.png",
    "category": "Office"
  },
  "npmRebuild": true,
  "asar": true,
  "asarUnpack": [
    ".next/standalone/**",
    "**/*.node",
    "**/better-sqlite3/**"
  ]
}
